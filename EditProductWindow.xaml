<Window x:Class="Test3.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test3"
        mc:Ignorable="d"
        Title="Продукт" Height="734" Width="800"
        Icon="D:\Download\Демонстрационный экзамен\1 июня\312\Модуль 1\import\icon.ico">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="5" MinWidth="200">
            <Label Content="Артикул"/>
            <TextBox Text="{Binding Article}" Name="ArticleTextBox"/>
            <Label Content="Название"/>
            <TextBox Text="{Binding Name}" Name="NameTextBox"/>
            <Label Content="Категория"/>
            <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.Categories}" SelectedValuePath="Id" DisplayMemberPath="Name" Name="CategoryComboBox"/>
            <Label Content="Единица измерения"/>
            <TextBox Text="{Binding Measurement}" Name="MeasurementTextBox"/>
            <Label Content="Цена"/>
            <TextBox Text="{Binding Price}" Name="PriceTextBox"/>
            <Label Content="Скидка"/>
            <TextBox Text="{Binding Discount}" Name="DiscountTextBox"/>
            <Label Content="Поставщик"/>
            <ComboBox ItemsSource="{Binding Suppliers}" SelectedValuePath="Id" DisplayMemberPath="Name" SelectedValue="{Binding SupplierId}" Name="SupplierComboBox"/>
            <Label Content="Производитель"/>
            <ComboBox ItemsSource="{Binding Producers}" SelectedValuePath="Id" DisplayMemberPath="Name" SelectedValue="{Binding ProducerId}" Name="ProducerComboBox"/>
            <Label Content="Количество"/>
            <TextBox Text="{Binding Amount}" Name="AmountTextBox"/>
            <Label Content="Описание"/>
            <TextBox Text="{Binding Description}" Name="DescriptionTextBox" TextWrapping="Wrap" Height="100"/>
            <Label Content="Изображение"/>
            <StackPanel Orientation="Horizontal">
                <Image Name="ProductImage" Width="150" Height="100" Stretch="Uniform" Margin="5"/>
                <Button VerticalAlignment="Bottom" Content="Выбрать файл" Click="SelectImageButton_Click" Margin="5"/>
            </StackPanel>
            <Button Content="Отменить" Margin="0,5,0,5" Click="CancelButton_Click"/>
            <Button Content="Сохранить" Margin="0,5,0,5" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
