<Window x:Class="Test3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test3"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800"
        Icon="D:\Download\Демонстрационный экзамен\1 июня\312\Модуль 1\import\icon.ico">
    <Grid>
        <StackPanel Width="200" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Логин"/>
            <TextBox Name="LoginTextBox"/>
            <Label Content="Пароль"/>
            <PasswordBox Name="PasswordBox"/>
